<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="76dp"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp">

        <!-- Gradient / Gray ring -->
        <ImageView
            android:id="@+id/ivStoryRing"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/story_ring_gradient"
            android:contentDescription="@null" />

        <!-- White spacer between ring and avatar -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_white"
            android:contentDescription="@null" />

        <!-- Avatar circle -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_white"
            android:contentDescription="Avatar"
            android:scaleType="centerCrop" />

        <!-- "+" button for Your Story -->
        <TextView
            android:id="@+id/tvAddStory"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/bg_add_story_button"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- LIVE badge -->
        <TextView
            android:id="@+id/tvLive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="-4dp"
            android:background="@drawable/bg_live_badge"
            android:paddingStart="5dp"
            android:paddingTop="1dp"
            android:paddingEnd="5dp"
            android:paddingBottom="1dp"
            android:text="LIVE"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvUsername"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/colorTextPrimary"
        android:textSize="11sp" />

</LinearLayout>
