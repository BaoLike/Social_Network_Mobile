<?xml version="1.0" encoding="utf-8"?>
<!-- Each cell in the Posts grid: a square ImageView that fills its column.
     The root view's height is forced to equal its width in PostsGridAdapter. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cellRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="?attr/selectableItemBackground">


    <!-- Square thumbnail (aspect ratio enforced via paddingTop 100% in code) -->
    <ImageView
        android:id="@+id/ivPostThumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Post thumbnail"
        android:scaleType="centerCrop" />

    <!-- Video badge – shown only for video posts -->
    <ImageView
        android:id="@+id/ivVideoBadge"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:contentDescription="Video"
        android:src="@drawable/ic_camera"
        android:tint="@color/white"
        android:visibility="gone" />

    <!-- Multi-image badge -->
    <ImageView
        android:id="@+id/ivMultiBadge"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:contentDescription="Multiple"
        android:src="@drawable/ic_bookmark_outline"
        android:tint="@color/white"
        android:visibility="gone" />

    <!-- Selection overlay (used by AddImageActivity gallery) -->
    <View
        android:id="@+id/viewSelectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#6437A1EF"
        android:visibility="gone" />

</FrameLayout>
