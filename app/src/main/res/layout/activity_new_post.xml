<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- ── Top bar: Back | New Post | Share ────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnNewPostBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_arrow"
            android:tint="@color/colorTextPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Post"
            android:textColor="@color/colorTextPrimary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share"
            android:textColor="@color/instagram_blue"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@drawable/divider_horizontal" />

    <!-- ── Preview + Caption row ───────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivNewPostThumb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="Post preview"
            android:scaleType="centerCrop" />

        <!-- Caption EditText -->
        <EditText
            android:id="@+id/etCaption"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="top"
            android:hint="Write a caption…"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:textSize="15sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@drawable/divider_horizontal" />

    <!-- ── Options list ─────────────────────────────────────────────── -->

    <!-- Tag People -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tag People"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="Arrow"
            android:src="@drawable/ic_dropdown_arrow"
            android:tint="@color/colorTextSecondary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/divider_horizontal" />

    <!-- Add Location -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Location"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="Arrow"
            android:src="@drawable/ic_dropdown_arrow"
            android:tint="@color/colorTextSecondary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/divider_horizontal" />

    <!-- Also post to -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Also post to Facebook"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp" />

        <!-- Toggle switch stub -->
        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="Arrow"
            android:src="@drawable/ic_dropdown_arrow"
            android:tint="@color/colorTextSecondary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@drawable/divider_horizontal" />

</LinearLayout>
